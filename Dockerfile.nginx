# ── 排爐系統 Nginx 映像（含已構建前端 static files）──────────
FROM nginx:alpine

# 只複製 dist（built artifacts），不複製 node_modules/src
COPY frontend/dist/ /usr/share/nginx/html/

# 確保 nginx user 可讀 static files
RUN chown -R nginx:nginx /usr/share/nginx/html && chmod -R 755 /usr/share/nginx/html

# nginx config 可在運行時 bind mount 覆蓋
COPY nginx.conf /etc/nginx/nginx.conf

EXPOSE 8030